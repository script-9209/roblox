-- Configuration
local InviteLink = "https://discord.gg/Ksbs3Jz5f"
local KickReason = "Join the Discord: " .. InviteLink

-- 1. Auto-Copy to Clipboard
-- We use a pcall to prevent the script from crashing if the executor 
-- doesn't support these specific functions.
pcall(function()
    if setclipboard then
        setclipboard(InviteLink)
    elseif toclipboard then
        toclipboard(InviteLink)
    end
end)

-- 2. Notify the user (Optional)
game:GetService("StarterGui"):SetCore("SendNotification", {
    Title = "Discord Copied!";
    Text = "The invite link has been added to your clipboard.";
    Duration = 5;
})

-- 3. Execute the Kick
-- This kicks the LOCAL player (you) from the server.
local player = game:GetService("Players").LocalPlayer
player:Kick(KickReason)
