        if num then FOVCircle.Radius = num end
    end,
})

OthersTab:CreateSection("Aimbot Precision")
OthersTab:CreateInput({
    Name = "Smoothness",
    PlaceholderText = "0.05",
    Callback = function(Text)
        local num = tonumber(Text)
        if num then Smoothness = math.clamp(num, 0.001, 1) end
    end,
})

--- LOGIC LOOPS ---

RunService:BindToRenderStep("AimbotUpdate", Enum.RenderPriority.Camera.Value + 1, function()
    local Center = GetTrueCenter()
    FOVCircle.Position = Center

    if AimbotEnabled then
        local Target = nil
        local MaxDist = FOVCircle.Radius
        
        for _, v in pairs(Players:GetPlayers()) do
            if v ~= LocalPlayer and v.Character and v.Character:FindFirstChild(AimPart) then
                if v.Character:FindFirstChild("Humanoid") and v.Character.Humanoid.Health > 0 then
                    local Role = GetPlayerRole(v)
                    if SelectedRoleTarget ~= "All" and Role ~= SelectedRoleTarget then continue end
                    
                    local ScreenPoint, OnScreen = Camera:WorldToScreenPoint(v.Character[AimPart].Position)
                    if OnScreen then
                        local Dist = (Vector2.new(ScreenPoint.X, ScreenPoint.Y) - Center).Magnitude
                        if Dist < MaxDist then
                            if WallCheck and not IsVisible(v.Character[AimPart]) then continue end
                            Target = v
                            MaxDist = Dist
                        end
                    end
                end
            end
        end

        if Target then
            local TargetPos = Target.Character[AimPart].Position
            Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position, TargetPos), Smoothness)
        end
    end
end)

RunService.Heartbeat:Connect(function()
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= LocalPlayer and v.Character then
            local Highlight = v.Character:FindFirstChild("ESPHighlight")
            local Role = GetPlayerRole(v)
            
            -- Role Label Logic
            if RoleCheckVisuals and (Role == "Murderer" or Role == "Sheriff") then
                CreateLabel(v.Character, Role, RoleColors[Role])
            else
                local ExistingLabel = v.Character:FindFirstChild("RoleLabel")
                if ExistingLabel then ExistingLabel:Destroy() end
            end

            -- Highlight Logic
            if GeneralESP or RoleCheckVisuals then
                if not Highlight then
                    Highlight = Instance.new("Highlight")
                    Highlight.Name = "ESPHighlight"
                    Highlight.Parent = v.Character
                end
                Highlight.FillColor = RoleCheckVisuals and RoleColors[Role] or ESPColor
                Highlight.Enabled = true
            else
                if Highlight then Highlight.Enabled = false end
            end
        end
    end
end)
